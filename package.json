{
  "name": "say-auth",
  "version": "1.1.0",
  "description": "Enterprise-grade authentication library for Next.js with MFA, RBAC, and security features",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./react-native": "./dist/native/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "API.md",
    "EXAMPLES.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external next --external axios --target es2020",
    "build:native": "tsup src/native/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom --external next --external axios --target es2020",
    "prepublishOnly": "pnpm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "release:patch": "npm version patch && pnpm publish",
    "release:minor": "npm version minor && pnpm publish",
    "release:major": "npm version major && pnpm publish",
    "test:coverage": "jest --coverage",
    "docs": "typedoc",
    "security": "pnpm audit",
    "prepare": "pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "axios": ">=1.6.0",
    "next": ">=13.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "lucide-react": "^1.7.0",
    "otpauth": "^9.2.0",
    "qrcode": "^1.5.3",
    "rfc4648": "^1.5.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/jest": "^29.5.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagni-amsalu/say-auth-git.git"
  },
  "bugs": {
    "url": "https://github.com/sagni-amsalu/say-auth/issues"
  },
  "homepage": "https://github.com/sagni-amsalu/say-auth#readme",
  "keywords": [
    "auth",
    "authentication",
    "nextjs",
    "react",
    "react-native",
    "mfa",
    "2fa",
    "totp",
    "jwt",
    "refresh-token",
    "rbac",
    "security",
    "typescript"
  ],
  "author": {
    "name": "Sanyii",
    "email": "sanyii@itech.com",
    "url": "https://github.com/sagni-amsalu"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
